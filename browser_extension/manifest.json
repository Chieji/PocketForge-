{
  "manifest_version": 3,
  "name": "Facebook AI Operator",
  "version": "1.0",
  "description": "Automate Facebook tasks with AI.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
